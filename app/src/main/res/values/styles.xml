<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorSecondary">@color/accent_active</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:navigationBarColor">@color/app_panel</item>
        <item name="android:statusBarColor">@color/app_panel</item>
    </style>

    <style name="Widget.XYZShow.IconButton" parent="Widget.MaterialComponents.Button.OutlinedButton.Icon">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:text">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">20dp</item>
        <item name="iconSize">20dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconGravity">textTop</item>
    </style>
</resources>
